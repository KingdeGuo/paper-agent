# Paper Agent Environment Configuration
# Copy this file to .env and modify for your environment

# ─── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PAPER_AGENT_SECRET_KEY=change-this-to-a-random-secret-key

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── LLM Providers ──────────────────────────────────────────
# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=gpt-4o

# Qwen (https://help.aliyun.com/zh/model-studio)
QWEN_API_KEY=
QWEN_MODEL_NAME=qwen-max

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=deepseek-chat

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# Ollama (https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3

# ─── Embedding Model ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Cluster Mode (Production PostgreSQL) ───────────────────
CLUSTER__ENABLE_CLUSTERING=false
CLUSTER__DATABASE__TYPE=sqlite

# PostgreSQL (when CLUSTER__ENABLE_CLUSTERING=true)
CLUSTER__DATABASE__HOST=localhost
CLUSTER__DATABASE__PORT=5432
CLUSTER__DATABASE__NAME=paper_agent
CLUSTER__DATABASE__USER=paper_agent
CLUSTER__DATABASE__PASSWORD=
CLUSTER__DATABASE__POOL_SIZE=10
CLUSTER__DATABASE__MAX_OVERFLOW=20
CLUSTER__DATABASE__POOL_RECYCLE=3600

# ─── Redis (Cache & Task Queue) ─────────────────────────────
CLUSTER__REDIS__ENABLED=false
CLUSTER__REDIS__HOST=localhost
CLUSTER__REDIS__PORT=6379
CLUSTER__REDIS__DB=0
CLUSTER__REDIS__PASSWORD=

# ─── MinIO / S3 Object Storage ──────────────────────────────
CLUSTER__STORAGE__ENABLED=false
CLUSTER__STORAGE__PROVIDER=minio
CLUSTER__STORAGE__ENDPOINT=http://localhost:9000
CLUSTER__STORAGE__ACCESS_KEY=
CLUSTER__STORAGE__SECRET_KEY=
CLUSTER__STORAGE__BUCKET=paper-agent

# ─── Task Queue ─────────────────────────────────────────────
CLUSTER__TASK_QUEUE__TYPE=none
CLUSTER__TASK_QUEUE__CONCURRENCY=4
